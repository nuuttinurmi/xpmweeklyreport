{
  "name": "weeklyreport-codeapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx power-apps run",
    "build": "tsc -b && vite build",
    "build:uat": "tsc -b && vite build --mode uat",
    "build:prod": "tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "push": "npm run build && npx power-apps push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/power-apps": "^1.0.4",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
