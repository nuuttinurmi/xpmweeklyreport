# ── Local dev (.env.local) ────────────────────────────────────────────────────
# Copy to .env.local and fill in your values.
# For UAT/prod builds, copy to .env.uat / .env.prod instead.
# All three files (.env.local, .env.uat, .env.prod) are gitignored.

# Dataverse org URL — change per environment (no trailing slash):
#   dev:  https://audicodev.crm4.dynamics.com
#   uat:  https://audico-uat.crm4.dynamics.com
#   prod: https://audicoproduction.crm4.dynamics.com
VITE_DATAVERSE_URL=https://audicodev.crm4.dynamics.com

# Azure AD app registration — same values across all environments
VITE_MSAL_CLIENT_ID=your-client-id
VITE_MSAL_TENANT_ID=your-tenant-id

# Power Automate HTTP-triggered flow URL for PDF→SharePoint
# Leave empty to disable the "Generoi PDF →" button
VITE_PA_FLOW_URL=

# ── Build commands ─────────────────────────────────────────────────────────────
# npm run build        → reads .env.local  → npm run push  (deploys to dev)
# npm run build:uat    → reads .env.uat    → pac solution export (for UAT)
# npm run build:prod   → reads .env.prod   → pac solution export (for prod)
