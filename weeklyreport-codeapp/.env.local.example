# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Your Dataverse environment base URL (no trailing slash)
VITE_DATAVERSE_URL=https://yourorg.crm4.dynamics.com

# Azure AD app registration for MSAL token acquisition
VITE_MSAL_CLIENT_ID=your-client-id
VITE_MSAL_TENANT_ID=your-tenant-id

# Power Automate HTTP-triggered flow URL for PDF→SharePoint
# Leave empty to disable the "Generoi PDF →" button
VITE_PA_FLOW_URL=
